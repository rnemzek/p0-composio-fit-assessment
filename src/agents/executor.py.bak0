import os
import logging
from composio import Composio
from src.tools.github_connector import FauxGitHubConnector
from src.tools.gmail_connector import GmailConnector
from src.utils.util import Util  # Changed from getDateTimestamp to Util

# 1. Setup logger
logger_name = os.environ.get("COMPOSIO_P0_LOGGER_NAME", "agent_logger")
logger = logging.getLogger(logger_name)

class Executor:
    def __init__(self):
        # Added quotes around "COMPOSIO_API_KEY" to prevent NameError
        self.composio = Composio(
            api_key=os.environ.get("COMPOSIO_API_KEY"), 
            toolkit_versions={"slack": os.environ.get("SLACK_VERSION")}
        )
        self.user_id = os.environ.get("COMPOSIO_USER_ID")
        
        self.gh = FauxGitHubConnector()
        self.gm = GmailConnector()

    def run_cycle(self):
        # 1. Poll the Faux GitHub Tool
        updates = self.gh.poll_updates()
        
        if updates:
            logger.info(f"EXECUTOR: Found {len(updates)} GitHub events.")
            
            # 2. TRIGGER REAL SLACK MESSAGE
            try:
                # Call static method from Util class
                dateTimestamp = Util.getDateTimestamp()
                
                # Added 'f' prefix so {len(updates)} actually works
                msg = (f"🚀 POC Alert {dateTimestamp}: Detected {len(updates)} new GitHub issues!")
                
                self.composio.tools.execute(
                    user_id=self.user_id,
                    slug="SLACK_SEND_MESSAGE",
                    arguments={
                        "channel": os.environ.get("SLACK_CHANNEL_ID"),
                        "text": msg
                    }
                )
                logger.info("SLACK_TOOL: Message successfully sent to #composio-poc")
            except Exception as e:
                logger.error(f"SLACK_TOOL ERROR: {e}")

            # 3. Use the Gmail Tool
            try:
                subject = f"Composio 0.11.1 test: {dateTimestamp}"
                body = "This message was sent using the simplified Composio SDK."
                self.gm.send_mail(subject, body)
                logger.info("GMAIL_TOOL: Email sent successfully.")
            except Exception as e:
                logger.error(f"GMAIL_TOOL ERROR: {e}")
            
        return updates

